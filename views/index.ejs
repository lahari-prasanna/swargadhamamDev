<% layout("/layouts/boilerplate") %>
<body>

  <!-- Hero Section -->
  <section class="hero" id="home">
    <div class="hero-content">
    <h1 class="hero-title">
  <span data-i18n="hero_welcome">Welcome to</span>
  <span class="hero-highlight" data-i18n="hero_name" >Swargadhamam</span>
</h1>


      <h2 class="hero-subtitle" data-i18n="hero_subtitle" style="font-weight: bold;">
        A Sacred Final Resting Place in Nandyal, Kurnool
      </h2>

      <p data-i18n="hero_desc" style="font-weight: bold;">
        Join us in creating a dignified, peaceful, and beautiful cremation facility that honors the departed and
        provides solace to families during their most difficult moments.
      </p>

      <div class="hero-buttons">
        <button class="btn-primary text-dark donate-primary"
          onclick="window.location.href='/donate'"
          data-i18n="hero_donate">
          ❤️ Donate Now →
        </button>

        <button class="btn-secondary"
          onclick="window.location.href='/impact'"
          data-i18n="hero_learn">
          Learn More →
        </button>
      </div>
    </div>
  </section>

  <!-- Mission Section -->
  <section class="mission">
    <div class="mission-header">
      <div class="mission-subtitle" data-i18n="mission_subtitle">
        Our Mission & Vision
      </div>

      <h2 data-i18n="mission_title">
        Transforming a traditional cremation ground into a world-class facility with dignity and compassion
      </h2>
    </div>

    <div class="mission-cards">
      <div class="index-card">
        <div class="index-card-icon">👥</div>
        <h3 data-i18n="mission_card1_title">Serving Community</h3>
        <p data-i18n="mission_card1_desc">
          Providing a dignified and peaceful final resting place for all members of our community, regardless
                    of their background or circumstances.
        </p>
      </div>

      <div class="index-card">
        <div class="index-card-icon">🏢</div>
        <h3 data-i18n="mission_card2_title">Modern Facilities</h3>
        <p data-i18n="mission_card2_desc">
         Building state-of-the-art cremation facilities with proper infrastructure, landscaping, and amenities
                    for grieving families
        </p>
      </div>

      <div class="index-card">
        <div class="index-card-icon">🤝</div>
        <h3 data-i18n="mission_card3_title">Compassionate Care</h3>
        <p data-i18n="mission_card3_desc">
          Offering support and assistance to families during their most difficult times with empathy, respect,
                    and professionalism.
        </p>
      </div>
    </div>
  </section>

  <!-- Impact Section -->
  <section class="impact">
    <div class="impact-container">
      <div class="impact-header">
        <h2 data-i18n="impact_title">Our Impact</h2>
        <p class="impact-subtitle" data-i18n="impact_desc" style="color:black;font-weight:bold;">
          Making a meaningful difference in the lives of families we serve.
        </p>
      </div>

      <div class="impact-stats">
        <div class="stat">
          <h3>500+</h3>
          <p data-i18n="impact_families">Families Served</p>
        </div>
        <div class="stat">
          <h3>24/7</h3>
          <p data-i18n="impact_availability">Availability</p>
        </div>
        <div class="stat">
          <h3>100%</h3>
          <p data-i18n="impact_satisfaction">Satisfaction</p>
        </div>
        <div class="stat">
          <h3>10+</h3>
          <p data-i18n="impact_years">Years of Service</p>
        </div>
      </div>
    </div>
  </section>



  <!-- Journey Section -->
  <section class="journey" id="journey">
<!-- GAME STYLE SERVICE ROADMAP -->
