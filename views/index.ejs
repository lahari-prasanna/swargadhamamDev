<!-- FAQ Section -->
<section class="faq">
  <h2 data-i18n="faq_title">Frequently Asked Questions</h2>

  <div class="faq-container">

    <!-- Q1 -->
    <div class="faq-item">
      <div class="faq-question" onclick="toggleFAQ(this)">
        <span data-i18n="faq_q1">What is Swarga Dhamam?</span>
        <span class="faq-toggle">+</span>
      </div>
      <div class="faq-answer" data-i18n="faq_a1">
        Swarga Dhamam is a sacred Hindu cremation ground providing Antyeshti (last rites) services with dignity and devotion for families in and around Nandyal.
      </div>
    </div>

    <!-- Q2 -->
    <div class="faq-item">
      <div class="faq-question" onclick="toggleFAQ(this)">
        <span data-i18n="faq_q2">Who can avail services?</span>
        <span class="faq-toggle">+</span>
      </div>
      <div class="faq-answer" data-i18n="faq_a2">
        All Hindu families, without any discrimination of caste, community, or financial status, are welcome.
      </div>
    </div>

    <!-- Q3 -->
    <div class="faq-item">
      <div class="faq-question" onclick="toggleFAQ(this)">
        <span data-i18n="faq_q3">What services are available?</span>
        <span class="faq-toggle">+</span>
      </div>
      <div class="faq-answer" data-i18n="faq_a3">
        Traditional Hindu cremation services, Antyeshti ritual support, clean cremation areas, water, electricity, resting areas, pathways, and assistance during rituals if required.
      </div>
    </div>

    <!-- Q4 -->
    <div class="faq-item">
      <div class="faq-question" onclick="toggleFAQ(this)">
        <span data-i18n="faq_q4">What are the timings?</span>
        <span class="faq-toggle">+</span>
      </div>
      <div class="faq-answer" data-i18n="faq_a4">
        General timings are 6:00 AM to 6:00 PM. Emergency and special services are available 24/7 including nights and public holidays.
      </div>
    </div>

    <!-- Q5 -->
    <div class="faq-item">
      <div class="faq-question" onclick="toggleFAQ(this)">
        <span data-i18n="faq_q5">Is prior appointment required?</span>
        <span class="faq-toggle">+</span>
      </div>
      <div class="faq-answer" data-i18n="faq_a5">
        Yes, prior intimation is preferred. In emergencies, families can contact the management directly for immediate assistance.
      </div>
    </div>

      <!-- Q6 -->
    <div class="faq-item">
      <div class="faq-question" onclick="toggleFAQ(this)">
        <span data-i18n="faq_q6">What are the charges?</span>
        <span class="faq-toggle">+</span>
      </div>
      <div class="faq-answer" data-i18n="faq_a6">
        
💰 Charges are minimal and transparent.

Basic cremation services are provided at nominal rates

Additional facilities or special arrangements may have separate charges

No hidden costs

📌 Our focus is service and compassion, not profit.
      </div>
    </div>

    <!-- Q6 -->
    <div class="faq-item">
      <div class="faq-question" onclick="toggleFAQ(this)">
        <span data-i18n="faq_q7">Are services free for poor families?</span>
        <span class="faq-toggle">+</span>
      </div>
      <div class="faq-answer" data-i18n="faq_a7">
       Yes, Financially weak families may request support. Assistance is provided based on genuine need with management approval.
      </div>
    </div>

       <div class="faq-item">
      <div class="faq-question" onclick="toggleFAQ(this)">
        <span data-i18n="faq_q8">Are priests (Purohits) provided?</span>
        <span class="faq-toggle">+</span>
      </div>
      <div class="faq-answer" data-i18n="faq_a8">
        Families may bring their own Purohit.
If required, guidance can be given to arrange a priest based on availability.
      </div>
    </div>

       <div class="faq-item">
      <div class="faq-question" onclick="toggleFAQ(this)">
        <span data-i18n="faq_q9">What documents are required?</span>
        <span class="faq-toggle">+</span>
      </div>
      <div class="faq-answer" data-i18n="faq_a9">
        Only basic details of the deceased are required. Our staff will guide families through any necessary formalities.
      </div>
    </div>

       <div class="faq-item">
      <div class="faq-question" onclick="toggleFAQ(this)">
        <span data-i18n="faq_q10">Is the premises clean and eco-friendly?</span>
        <span class="faq-toggle">+</span>
      </div>
      <div class="faq-answer" data-i18n="faq_a10">
       Yes. Swarga Dhamam is maintained as a clean, green, and peaceful sacred space, respecting the environment and traditions.
      </div>
    </div>

       <div class="faq-item">
      <div class="faq-question" onclick="toggleFAQ(this)">
        <span data-i18n="faq_q11">Are facilities available for elderly family members?</span>
        <span class="faq-toggle">+</span>
      </div>
      <div class="faq-answer" data-i18n="faq_a11">
        Yes.

Seating areas

Shaded spaces

Drinking water

Safe walking paths

    </div>

      
    </div>

         <div class="faq-item">
      <div class="faq-question" onclick="toggleFAQ(this)">
        <span data-i18n="faq_q12">Who should be contacted for booking or emergencies?</span>
        <span class="faq-toggle">+</span>
      </div>
      <div class="faq-answer" data-i18n="faq_a12">
       
📞 Please contact the Swarga Dhamam Management Office for:

Prior booking

Emergency services

Charges and facility details
      </div>
    </div>
  </div>
</section>



  <!-- CTA Section -->
  <section class="cta" id="services">
    <div class="cta-overlay"></div>

    <h2 data-i18n="cta_title">Need Our Services?</h2>

    <p data-i18n="cta_desc" style="color:black;font-weight:bold;">
      Contact us today for immediate assistance. We are here to help you.
    </p>

  <div class="cta-input">
  <button 
    class="btn-primary"
    onclick="window.location.href='/contact'"
    data-i18n="cta_button">
    Contact Now →
  </button>
</div>
  </section>


  <div id="videoModal" class="video-modal">
    <div class="video-modal-content">
      <button class="close-btn" onclick="closeVideoModal()">✖</button>
      <video id="modalVideo" controls playsinline>
        <source id="modalSource" src="">
        Your browser does not support the video tag.
      </video>
    </div>
  </div>
  <script>
    function openVideoModal(videoUrl) {
      const modal = document.getElementById("videoModal");
      const source = document.getElementById("modalSource");
      const video = document.getElementById("modalVideo");
  
      source.src = videoUrl;
      video.load();
      modal.style.display = "block";
  
      document.body.style.overflow = "hidden"; // prevent background scroll
    }
  
    function closeVideoModal() {
      const modal = document.getElementById("videoModal");
      const video = document.getElementById("modalVideo");
  
      video.pause();
      video.currentTime = 0;
      modal.style.display = "none";
  
      document.body.style.overflow = "auto";
    }
  
    // close when clicking outside
    window.onclick = function(event) {
      const modal = document.getElementById("videoModal");
      if (event.target === modal) {
        closeVideoModal();
      }
    };
  </script>

  <script src="/js/index.js"></script>
</body>
</html>
