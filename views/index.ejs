M600 0
C200 200,1000 350,600 550
C200 750,1000 900,600 1100
C200 1300,1000 1500,600 1700
C200 1850,1000 1950,600 2100
"
stroke="#2ecc71"
stroke-width="8"
fill="none"
stroke-dasharray="12 10"
/>

<!-- CHECKPOINTS -->

<circle class="checkpoint" cx="600" cy="120" r="10"/>
<circle class="checkpoint" cx="350" cy="350" r="10"/>
<circle class="checkpoint" cx="780" cy="600" r="10"/>
<circle class="checkpoint" cx="420" cy="850" r="10"/>
<circle class="checkpoint" cx="780" cy="1100" r="10"/>
<circle class="checkpoint" cx="420" cy="1350" r="10"/>
<circle class="checkpoint" cx="780" cy="1600" r="10"/>
<circle class="checkpoint" cx="420" cy="1850" r="10"/>

</svg>

<div class="road-vehicle">🚐</div>

<!-- SERVICE CARDS -->

<div class="map-card step1">
<h3>🕉️ Cremation Services</h3>
<p>Booking, timings, rituals & emergency cremation support.</p>
<a href="tel:9515516315">📞 Call Coordinator</a>
</div>

<div class="map-card step2">
<h3>❄️ Freezer Box Services</h3>
<p>Freezer box availability, transport and emergency arrangements.</p>
<a href="tel:9177136439">📞 Call In-Charge</a>
</div>

<div class="map-card step3">
<h3>🚐 Vaikuntha Radham</h3>
<p>Funeral vehicle booking and route coordination.</p>
<a href="tel:9963711886">📞 Call Vehicle Team</a>
</div>

<div class="map-card step4">
<h3>🌿 Memorial Tree Plantation</h3>
<p>Plant a tree in memory of your loved ones.</p>
<a href="tel:9160038115">📞 Contact Green Team</a>
</div>

<div class="map-card step5">
<h3>💰 Donations & Seva</h3>
<p>Support poor families and development initiatives.</p>
<a href="tel:9985002900">📞 Trust Office</a>
</div>

<div class="map-card step6">
<h3>🕊️ Support for Poor Families</h3>
<p>Free or subsidized services for families in need.</p>
<a href="tel:9440290460">📞 Welfare Support</a>
</div>

<div class="map-card step7">
<h3>📜 Ritual Guidance</h3>
<p>Antyeshti procedure guidance and priest coordination.</p>
<a href="tel:7093464195">📞 Ritual Support</a>
</div>

<div class="map-card step8">
<h3>🏛️ Management Office</h3>
<p>Official enquiries, trust information and suggestions.</p>
<a href="tel:9985002900">📞 Office Contact</a>
</div>

</div>



</section>

    <div class="journey-content">
      <h2 class="journey-title" data-i18n="journey_title">Our Journey So Far</h2>

      <p class="journey-text" data-i18n="journey_desc">
        We are committed to serving every family with dignity, respect, and compassion.
      </p>

      <button class="btn-journey"
        onclick="window.location.href='/about'"
        data-i18n="journey_button">
        Read Our Story →
      </button>
    </div>
  </section>

  <section class="testimonials-section ">
    <div class="testimonials-overlay"></div>

    <h2 class="testi-title">What People Say</h2>
    <p class="testi-subtitle">
        Hear from families and donors who have experienced Swargadhamam
    </p>
   
    <div class="testi-wrapper">

        <% testimonials.forEach(t => { %>
            <div class="testi-card animate" data-animate="<%= t.animation %>">
                
                <div class="testi-header">
                    <div class="avatar">
                        A
                    </div>
                    <div>
                        
                        <h3><%= t.owner?.username || t.username || 'Unknown' %></h3>


                        <span><%= t.role %></span>
                    </div>
                </div>
        
                <div class="stars">
                    <%= "★".repeat(t.stars) %>
                </div>
        
                <p class="review">
                    "<%= t.review %>"
                </p>
                
                <% if (t.video && t.video.url) { %>
                    <div class="video-link">
                      <button 
                        class="watch-video-btn mb-2"
                        onclick="openVideoModal('<%= t.video.url %>')">
                        ▶ Watch Video
                      </button>
                    </div>
                  <% } %>
                  
         
                  <% if (currUser && ( currUser.role === "admin" || (t.owner && t.owner._id ? String(t.owner._id) === String(currUser._id) : false) )) { %>

                <div class="actions">
                    <a href="/testimonials/<%= t._id %>/edit" class="btn btn-secondary mb-2">
                      Edit
                    </a>
                
                    <form action="/testimonials/<%= t._id %>?_method=DELETE" method="POST">
                      <button class="btn btn-danger mb-2">Delete</button>
                    </form>
                  </div>
                <%}%>
        
            </div>
        <% }) %>
        

    </div>
    
      
    <div class="cols-6 ">
        <% if(currUser) {%>
        <form action="/testimonials" method="POST" enctype="multipart/form-data"  class="testimonial-form">
            <% if(currUser.role === "admin") { %>
                <div class="mb-3">
                  <input type="text" name="username" class="form-control" placeholder="User Name (for old testimonial)">
                </div>
              <% } %>
              
            <div class="mb-3">
                <select name="role" class="form-control" required>
                    <option value="">Select Role</option>
                    <option value="Family Member">Family Member</option>
                    <option value="Donor">Donor</option>
                    <option value="Community Leader">Community Leader</option>
                  </select>
            </div>
            <div class="mb-3">
                <textarea name="review" class="form-control" rows="7" cols="10" placeholder="Your Review" required></textarea>
            </div>
            <div class="mb-3">
                <label class="form-label">Upload Video (Optional)</label>
                <input type="file"
                       name="video"
                       class="form-control"
                       accept="video/mp4,video/webm,video/mov">
                <small style="font-size:12px; color:gray;">
                  Optional. Max 30MB. MP4 recommended.
                </small>
              </div>
              
            
                <!-- ⭐ STAR RATING -->
            <div class="star-rating form-control mb-3">
              <span data-value="1">★</span>
              <span data-value="2">★</span>
              <span data-value="3">★</span>
              <span data-value="4">★</span>
              <span data-value="5">★</span>
            
            </div>
       
            <!-- hidden input (important) -->
            <input type="hidden" name="stars" id="stars" value="5" />
          
            <button type="submit" class="btn btn-dark my-3">Submit Testimonial</button>
          </form>
          <%}%>
    </div>
</section>

