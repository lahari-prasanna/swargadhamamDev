<% layout('/layouts/boilerplate') %>
<body>
  <form method="POST" class="needs-validation" novalidate action="/gallery" enctype="multipart/form-data">
    <div class="row">
      <div class="col-8 offset-2">
        <h3 class="mt-3">Add your listing</h3>
        <div class="mb-3">
          <label for="title" class="form-label">Title</label>

          <input
            type="text"
            name="item[title]"
            value=""
            class="form-control"
            required
          />
          <div class="invalid-feedback">Please Enter a valid title </div>
        </div>

       

        <div class="mb-3">
          <label for="image" class="form-label">Upload Image</label>
          <input
            name="item[image]"
            type="file"
            class="form-control-file"
          />
          <div class="invalid-feedback">Please upload a image</div>
        </div>

       
       

        

        <button class="btn btn-dark mb-3 edit-btn">Add</button>
    </div>
      </div>
    </div>
  </form>
</body>
