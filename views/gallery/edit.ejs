<% layout('/layouts/boilerplate') %>
<body>
  <form method="POST"  novalidate class="needs-validation" action="/gallery/<%= item._id %>?_method=PUT" enctype="multipart/form-data">
    <div class="row">
      <div class="col-8 offset-2">
        <h3 class="mt-3">Edit your listing</h3>
        <div class="mb-3">
          <label for="title" class="form-label">Title</label>

          <input
            type="text"
            name="item[title]"
            value="<%= item.title %>"
            class="form-control"
            required
          />
          <div class="invalid-feedback">Please Enter a title</div>
        </div>

        <div class="mb-3">
          <p>Original Listing image</p>
          <img
            src="<%= item.image.url %>"
            alt=""
            height="200"
            width="300"
          />
        </div>

        <div class="mb-3">
          <label for="image" class="form-label">Image</label>
          <input
            name="item[image]"
            type="file"
            class="form-control"
          />
         
        </div>

       
       

        

        <button class="btn btn-dark mb-3 edit-btn">Edit</button>
    </div>
      </div>
    </div>
  </form>
</body>
