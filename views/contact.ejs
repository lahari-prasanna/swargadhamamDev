<% layout("/layouts/boilerplate") %>
<body>


<section class="contact-section">
  <div class="contact-header">
    <span class="tag">Get in Touch</span>
    <h2>Contact Us</h2>
    <p>We're here to answer your questions and provide support</p>
  </div>

  <div class="contact-grid">
    <!-- LEFT: FORM -->
    <div class="contact-form custom-card">
      <h3>Send Us a Message</h3>

<form action="/contact-message" method="POST" class="contact-form">

<label>Full Name</label>
<input type="text" name="name" placeholder="Enter your name" required>

<label>Email Address</label>
<input type="email" name="email" placeholder="your@email.com" required>

<label>Phone Number</label>
<input type="tel" name="phone" placeholder="+91 XXXXX XXXXX" required>

<label>Subject</label>
<input type="text" name="subject" placeholder="How can we help?" required>

<label>Message</label>
<textarea name="message" placeholder="Tell us more about your inquiry..." required></textarea>

<button type="submit" class="send-btn">
Send Message
</button>

</form>
    </div>

    <!-- RIGHT: CONTACT INFO -->
    <div class="contact-info custom-card green-gradient">
      <h3>Contact Information</h3>

     <p class="a1 address-text"  style="color:white !important;">
<strong  style="color:black !important;">Address</strong><br>
Swargadhamam Cremation Ground<br>
Nandyal, Kurnool District<br>
Andhra Pradesh, India
</p>

<div class="contact-info">

  <p class="contact-item">
    <strong>Phone</strong><br>
    <a href="tel:+919985002900" style="color:white">+91 9985002900</a><br>
    <a href="tel:+919440290460"  style="color:white">+91 9440290460 (Alt)</a>
  </p>

  <p class="contact-item">
    <strong>Email</strong><br>
    <a href="mailto:swargadhamamnandyal@gmail.com" style="color:white">
      swargadhamamnandyal@gmail.com
    </a>
  </p>

</div>

      

      <div class="social-icons">
        <i class="fab fa-facebook"></i>
        <i class="fab fa-twitter"></i>
        <i class="fab fa-instagram"></i>
        <i class="fab fa-youtube"></i>
      </div>
    </div>
  </div>

  <!-- VISIT CARD -->
  <div class="visit custom-card">
    <h3>Visit Us</h3>
    <p>We welcome visitors to see our facility and discuss how you can support our mission.</p>
    <p>Please call ahead to schedule a visit or tour of the premises.</p>
  </div>

  <!-- MAP -->
<!-- LOCATION SECTION -->
<section class="location-section">

  <div class="location-header">
    <h3>📍 Visit Swarga Dhamam</h3>
    <p>Find us easily using the map below.</p>
  </div>

  <!-- Address Card -->
  <div class="location-card">

    <div class="location-details">

      <h4>Swarga Dhamam</h4>

      <p>
        SWARGA DHAMAM, HINDU GRAVEYARD<br>
        Bhimavaram Road<br>
        Beside Municipal Dump Yard<br>
        Nandyal, Andhra Pradesh
      </p>

      <a 
      href="https://www.google.com/maps/dir/?api=1&destination=Swarga+Dhamam+Hindu+Graveyard+Bhimavaram+Road+Nandyal"
      target="_blank"
      class="direction-btn">

      🧭 Get Directions

      </a>

    </div>

  </div>


  <!-- MAP -->
  <div class="map custom-card">

    <iframe
    src="https://www.google.com/maps?q=Swarga+Dhamam+Hindu+Graveyard+Bhimavaram+Road+Bedide+Municipal+Dump+Yard+Nandyal&output=embed"
    style="border:0;width:100%;height:100%;"
    allowfullscreen=""
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade">
    </iframe>

  </div>

</section>


</section>




