<% layout("/layouts/boilerplate") %>

<body>

  <section class="gallery-section py-20 px-6 bg-gray-50" id="gallery">

    <!-- Video Hero -->
    <div class="video-hero relative mb-16">
      <div class="video-container floating-video">
        <video id="missionVideo" class="video-element rounded-xl shadow-lg" playsinline>
          <source src="images/v1.mp4" type="video/mp4">
          Your browser does not support the video tag.
        </video>

        <!-- Custom Controls -->

        <div class="video-controls">
          <button id="playPause">▶</button>
          <input type="range" id="seekBar" value="0" min="0" max="100">
          <button id="muteBtn">🔊</button>
          <input type="range" id="volumeBar" min="0" max="1" step="0.1" value="1">
          <button id="fullscreenBtn">⛶</button>
        </div>
      </div>


      <!-- Caption Box Below Video -->
      <div class="video-caption-box">
        <h2 class="caption-title">Our Journey in Pictures</h2>
        <p class="caption-subtitle">Every frame tells a story of dignity, compassion, and community.</p>
        <a href="#donate" class="support-btn" onclick="window.location.href='donate.html'">Support Our
          Mission</a>
      </div>
    </div>
    </div>


    <!-- Gallery Filter Buttons -->
    <div class="gallery-filters">
      <button class="filter-btn active" data-filter="all">All</button>
      <button class="filter-btn" data-filter="facilities">Facilities</button>
      <button class="filter-btn" data-filter="events">Events</button>
      <button class="filter-btn" data-filter="community">Community</button>
