    <div class="container py-4">
      <div class="row g-4">
    
        <% allPhotos.forEach((item, index) => { %>
          <div class="col-12 col-sm-6 col-md-4 col-lg-3">
            <a href="/gallery/<%= item._id %>" class="text-decoration-none">
    
              <div class="gallery-item overflow-hidden rounded">
                <img
                  src="<%= item.image.url %>"
                  alt="<%= item.title || `Gallery ${index + 1}` %>"
                  class="img-fluid gallery-img"
                />
    
                <% if(item.title) { %>
                <div class="caption text-center mt-2 text-dark">
                  <%= item.title %>
                </div>
                <% } %>
              </div>
    
            </a>
          </div>
        <% }) %>
    
      </div>
    </div>
    
    <!-- Lightbox Modal -->
    <div id="lightbox">
      <button id="closeLightbox">&times;</button>
      <button id="prev">&#10094;</button>
      <img id="lightboxImg" src="" alt="Gallery Image" />
      <button id="next">&#10095;</button>
    </div>



    <script src="/js/gallery.js"></script>
</body>