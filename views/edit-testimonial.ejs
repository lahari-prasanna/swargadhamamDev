<% layout("/layouts/boilerplate") %>
<body>
  <form
    action="/testimonials/<%= testimonial._id %>?_method=PUT"
    method="POST"
  >
    <div class="row">
      <div class="col-8 offset-2">
        <div class="my-3">
          <select name="role" class="form-control">
            <option selected><%= testimonial.role %></option>
            <option>Family Member</option>
            <option>Donor</option>
            <option>Community Leader</option>
          </select>
        </div>
        <div class="my-3">
          <textarea class="form-control" name="review">
    <%= testimonial.review %></textarea
          >
        </div>
        <div class="my-3">
          <input
            type="hidden"
            name="stars"
            value="<%= testimonial.stars %>"
            class="form-control"
          />
        </div>
        <div class="my-3">
          <button class="btn btn-success">Update</button>
        </div>
      </div>
    </div>
  </form>
</body>
