<script src="https://checkout.razorpay.com/v1/checkout.js"></script>


<script>

document.addEventListener("DOMContentLoaded", function(){

const donateBtn = document.getElementById("donate-btn");

donateBtn.addEventListener("click", function(){

const amount = document.getElementById("donation-amount").value;
const name = document.getElementById("donor-name").value;
const email = document.querySelector('input[type="email"]').value;

if(amount === "" || name === "" || email === ""){

alert("Please fill all required fields before donating.");
return;

}

document.getElementById("payment-options").style.display = "block";

});

// ⭐ ADD THIS BLOCK
document.querySelectorAll('.amount-btn').forEach(btn => {

btn.addEventListener('click', function(){

const amount = this.dataset.amount;

document.getElementById("donation-amount").value = amount;

});

});

});

function showPayment(type){

document.getElementById("qr-display").style.display="none";
document.getElementById("bank").style.display="none";
document.getElementById("razorpay").style.display="none";

if(type === "qr"){
document.getElementById("qr-display").style.display="block";
}

if(type === "bank"){
document.getElementById("bank").style.display="block";
}

if(type === "razorpay"){
document.getElementById("razorpay").style.display="block";
}

}


function payWithRazorpay(){

let amount = document.getElementById("donation-amount").value;
let name = document.getElementById("donor-name").value;
let email = document.querySelector('input[type="email"]').value;

if(amount === "" || name === "" || email === ""){
alert("Please fill donation details first");
return;
}

var options = {

"key": "rzp_live_SPBeD2QU7emdWj",

"amount": amount * 100,

"currency": "INR",

"name": "Swargadhamam",

"description": "Donation",

handler: async function (response){

alert("Payment Successful!");

let name = document.getElementById("donor-name").value;
let email = document.querySelector('input[type="email"]').value;
let amount = document.getElementById("donation-amount").value;

await fetch("/send-certificate",{

method:"POST",

headers:{
"Content-Type":"application/json"
},

body:JSON.stringify({
name:name,
email:email,
amount:amount,
paymentMethod:"razorpay"
})

});

alert("Certificate sent to your email!");

},


"prefill": {

"name": name,
"email": email

},

"theme": {
"color": "#16a34a"
}

};

var rzp = new Razorpay(options);

rzp.open();

}


async function loadDonors(){

try{

const res = await fetch("/api/donors");
const data = await res.json();

const donorList = document.getElementById("donor-list");
const totalDonation = document.getElementById("total-donation");

if(!donorList) return;

donorList.innerHTML = "";

data.donors.forEach(donor=>{

const li = document.createElement("li");

li.style.display="flex";
li.style.justifyContent="space-between";
li.style.padding="6px 10px";
li.style.borderBottom="1px solid #eee";

li.innerHTML=`
<span> 🤝${donor.name}</span>
<span>₹${donor.amount}</span>
`;

donorList.appendChild(li);

});

if(totalDonation){
totalDonation.innerText = data.total;
}

}catch(err){

console.log("Donor loading error",err);

}

}

document.addEventListener("DOMContentLoaded", function(){

loadDonors();

setInterval(loadDonors,5000);

});


function sendBankCertificate(){

let name = document.getElementById("donor-name").value;
let email = document.querySelector('input[type="email"]').value;
let amount = document.getElementById("donation-amount").value;

if(name === "" || email === "" || amount === ""){
alert("Please fill name, email and amount to receive certificate");
return;
}

fetch("/send-certificate",{

method:"POST",

headers:{
"Content-Type":"application/json"
},

body:JSON.stringify({
name:name,
email:email,
amount:amount,
paymentMethod:"bank"
})

});

alert("Certificate will be sent to your email!");

}
</script>
