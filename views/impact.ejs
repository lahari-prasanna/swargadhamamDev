<% layout("/layouts/boilerplate") %>
<body>
    
    <!-- Impact Section -->
    <section id="impact" class="impact-section">
        <div class="impact-bg"></div> <!-- Parallax background -->

        <h2 class="impact-heading">Making a Difference</h2>
        <p class="impact-subheading">See how your support is transforming Swargadhamam into a beacon of dignity and
            compassion</p>

        <!-- Floating Hearts Background -->
        <div class="floating-hearts-bg">
            <div class="heart"></div>
            <div class="heart"></div>
            <div class="heart"></div>
            <div class="heart"></div>
            <div class="heart"></div>
        </div>

        <!-- Impact Stats -->
        <div class="impact-stats">
            <div class="stat-box animate-on-scroll" style="--delay:0s">
                <!-- Hearts inside card -->
                <div class="card-hearts">
                    <div class="heart"></div>
                    <div class="heart"></div>
                    <div class="heart"></div>
                    <div class="heart"></div>
                    <div class="heart"></div>
                    <div class="heart"></div>
                </div>

                <h3 class="counter" data-target="500">0</h3>
                <p>Harmless Served</p>
            </div>

            <div class="stat-box animate-on-scroll" style="--delay:0.2s">
                <div class="card-hearts">
                    <div class="heart"></div>
                    <div class="heart"></div>
                    <div class="heart"></div>
                    <div class="heart"></div>
                    <div class="heart"></div>
                    <div class="heart"></div>
                </div>

                <h3 class="counter" data-target="75">0</h3>
                <p>Construction Complete (%)</p>
            </div>

            <div class="stat-box animate-on-scroll" style="--delay:0.4s">
                <div class="card-hearts">
                    <div class="heart"></div>
                    <div class="heart"></div>
                    <div class="heart"></div>
                    <div class="heart"></div>
                    <div class="heart"></div>
                    <div class="heart"></div>
                </div>

                <h3 class="counter" data-target="1000">0</h3>
                <p>Generous Donors</p>
            </div>


            <div class="stat-box animate-on-scroll" style="--delay:0.6s">
                <div class="card-hearts">
                    <div class="heart"></div>
                    <div class="heart"></div>
                    <div class="heart"></div>
                    <div class="heart"></div>
                    <div class="heart"></div>
                    <div class="heart"></div>
                </div>

                <h3 class="counter" data-target="25">0</h3>
                <p>Funds Raised (Lakhs)</p>
            </div>
        </div>


        <!-- Accomplishments -->
        <div class="impact-accomplishments">
            <div class="impact-card animate-on-scroll" style="--delay:0s">
                <h4>🌱 Land Development</h4>
                <p>Leveled and seeded 5 acres with drainage and foundation.</p>
            </div>
            <div class="impact-card animate-on-scroll" style="--delay:0.2s">
                <h4>🚪 Infrastructure Setup</h4>
                <p>Entry gate, boundary walls, and internal road network.</p>
            </div>
            <div class="impact-card animate-on-scroll" style="--delay:0.4s">
                <h4>🪑 Waiting Areas</h4>
                <p>Comfortable seating, shade, and water facilities.</p>
            </div>
            <div class="impact-card animate-on-scroll" style="--delay:0.6s">
                <h4>🌳 Landscaping</h4>
                <p>Clean green spaces for peaceful environment.</p>
            </div>
            <div class="impact-card animate-on-scroll" style="--delay:0.8s">
                <h4>💧 Water & Electricity</h4>
                <p>Installed supply and connections throughout.</p>
            </div>
            <div class="impact-card animate-on-scroll" style="--delay:1s">
                <h4>🚻 Sanitation Facilities</h4>
                <p>Modern toilets and hygiene stations.</p>
            </div>
        </div>



        <!-- Before & After Row -->
        <div class="impact-before-after-row">
            <div class="before-after-card animate-on-scroll" style="--delay:0s">
                <div class="side before">
                    <h4>Before</h4>
                    <img src="/images/before.jpg" alt="Before 1">
                </div>
                <div class="divider-vertical"></div>
                <div class="side after">
                    <h4>After</h4>
                    <img src="images/after.jpg" alt="After 1">
                </div>
            </div>

            <div class="before-after-card animate-on-scroll" style="--delay:0.2s">
                <div class="side before">
                    <h4>Before</h4>
                    <img src="images/before1.jpg" alt="Before 2">
                </div>
                <div class="divider-vertical"></div>
                <div class="side after">
                    <h4>After</h4>
                    <img src="images/after2.jpg" alt="After 2">
                </div>
            </div>

            <div class="before-after-card animate-on-scroll" style="--delay:0.4s">
                <div class="side before">
                    <h4>Before</h4>
                    <img src="images/construction.jpg" alt="Before 3">
                </div>
                <div class="divider-vertical"></div>
                <div class="side after">
                    <h4>After</h4>
                    <img src="images/after3.jpg" alt="After 3">
                </div>
            </div>

            <div class="before-after-card animate-on-scroll" style="--delay:0.6s">
                <div class="side before">
                    <h4>Before</h4>
                    <img src="images/entrance.jpg" alt="Before 4">
                </div>
                <div class="divider-vertical"></div>
                <div class="side after">
                    <h4>After</h4>
                    <img src="images/people.jpg" alt="After 4">
                </div>
            </div>
        </div>


<!-- Future Plans Section -->
<section class="future-plans">

<h2 class="future-title">🌅 Future Plans</h2>
<h3 class="future-subtitle">Swarga Dhamam</h3>

<div class="future-grid">

<div class="future-card"  data-aos="fade-up">
<h4>🌿 Green & Eco-Friendly Expansion</h4>
<p>
To further develop Swarga Dhamam into a model clean and green sacred space,
with more trees, landscaped pathways, and eco-conscious facilities that
reflect harmony with nature.
</p>
</div>

<div class="future-card"  data-aos="fade-up" data-aos-delay="100">
<h4>🔥 Modern & Dignified Cremation Facilities</h4>
<p>
To introduce improved and eco-friendly cremation systems that preserve
Hindu traditions while ensuring cleanliness, safety, and environmental responsibility.
</p>
</div>

<div class="future-card" data-aos="fade-up" data-aos-delay="200">
<h4>🏛️ Enhanced Family Support Facilities</h4>
<ul>
<li>Comfortable waiting halls</li>
<li>Sheltered seating for elders</li>
<li>Drinking water and sanitation blocks</li>
<li>Clear signage for easy guidance</li>
</ul>
<p>Ensuring dignity and comfort for every family.</p>
</div>

<div class="future-card" data-aos="fade-up" data-aos-delay="300">
<h4>🕉️ Spiritual Guidance & Ritual Support</h4>
<ul>
<li>On-site ritual guidance</li>
<li>Support for families unfamiliar with rites</li>
<li>Access to trained Purohits when needed</li>
</ul>
<p>So that no family feels lost during the final journey.</p>
</div>

<div class="future-card" data-aos="fade-up" data-aos-delay="400">
<h4>🤝 Support for the Needy</h4>
<p>
To strengthen free or subsidized services for poor and vulnerable families,
ensuring that financial limitations never stand in the way of sacred last rites.
</p>
</div>

<div class="future-card" data-aos="fade-up" data-aos-delay="500">
<h4>🌱 Environmental & Social Initiatives</h4>
<ul>
<li>Tree plantation in memory of departed souls</li>
<li>Promotion of eco-friendly rituals</li>
<li>Awareness programs on cleanliness and dignity</li>
</ul>
</div>

<div class="future-card" data-aos="fade-up" data-aos-delay="600">
<h4>🧘 Peace & Reflection Zones</h4>
<p>
To create quiet prayer and meditation spaces where families can find
mental peace, solace, and spiritual strength.
</p>
</div>

<div class="future-card"  data-aos="fade-up" data-aos-delay="700">
<h4>🏗️ Infrastructure & Safety Development</h4>
<ul>
<li>Improved roads and pathways</li>
<li>Better lighting and security</li>
<li>Water management and drainage</li>
</ul>
<p>Ensuring safe and smooth operations.</p>
</div>

<div class="future-card"  data-aos="fade-up" data-aos-delay="800">
<h4>🕊️ Community Participation & Seva</h4>
<ul>
<li>Volunteer service (Seva)</li>
<li>Community involvement</li>
<li>Donations for sustainable development</li>
</ul>
<p>So Swarga Dhamam remains a collective responsibility and pride.</p>
</div>

</div>

<p class="future-quote" data-aos="fade-up" data-aos-delay="900">
✨ “Our future is built on compassion, sustainability, and sacred responsibility.”
</p>

</section>
    </section>

 

    <script src="/js/impact.js"></script>
</body>

</html>